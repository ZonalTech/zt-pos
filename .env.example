# Copy this file to ".env" and adjust to match your local MariaDB setup.

# --- Local MariaDB connection ---
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pos_db

# --- App / business settings ---
SECRET_KEY=please-change-this
# Dev only: auto-sign-in as an admin so a server restart doesn't show the login
# form. Leave at 0 (or unset) in production.
DEV_AUTO_LOGIN=0
STORE_NAME=My Shop
# Base/accounting currency. All stored totals and reports use this.
CURRENCY=KES
# Set a VAT/sales-tax rate as a decimal, e.g. 0.16 for 16%. 0 = no tax.
TAX_RATE=0

# --- Multi-currency ---
# Extra currencies a cashier may accept at the till (comma-separated). The base
# CURRENCY above is always available regardless of this list.
SUPPORTED_CURRENCIES=USD,EUR,GBP,UGX,TZS
# Live FX source. "{base}" is replaced with the base currency code.
# open.er-api.com is free and needs no API key.
RATE_API_URL=https://open.er-api.com/v6/latest/{base}
# How long a cached live rate stays fresh before a refresh is attempted (hours).
RATE_REFRESH_HOURS=12

# --- Updates (GitHub Releases) ---
# Updates are published as GitHub Releases. Point the app at your repo in
# "owner/name" form; it checks the repo's latest release automatically. The repo
# must be public so the updater can read releases and download the update zip.
GITHUB_REPO=ZonalTech/zt-pos
# Optional: override the full check URL. Leave unset to use
# https://api.github.com/repos/<GITHUB_REPO>/releases/latest
# UPDATE_URL=https://api.github.com/repos/ZonalTech/zt-pos/releases/latest
